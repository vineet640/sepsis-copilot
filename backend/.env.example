GEMINI_API_KEY=
# Comma-separated fallback list; default tries gemini-2.5-flash first (avoids 2.0 quota / 1.5 404 on some keys).
# GEMINI_MODEL=gemini-2.5-flash,gemini-2.0-flash
ELEVENLABS_API_KEY=
# Optional overrides. Defaults use premade voices (Alice + Antoni) so free-tier API works; Voice Library IDs need a paid plan.
# ELEVENLABS_VOICE_CALM=
# ELEVENLABS_VOICE_URGENT=
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=sepsis-copilot-audio
CORS_ORIGIN=http://localhost:5173
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.devnet.solana.com
